                "cache_ttl": null,
                "dataset_query": {
                    "lib/type": "mbql/query",
                    "database": 2,
                    "stages": [
                        {
                            "lib/type": "mbql.stage/native",
                            "native": "SELECT\n    DATE_TRUNC('month', w.trx_date) AS month,\n    ROUND(SUM(w.time_spent_hours)::numeric, 1) AS hours_logged,\n    COUNT(DISTINCT w.issue_key) AS issues_worked\nFROM core.fact_worklogs w\nWHERE w.trx_date >= CURRENT_DATE - INTERVAL '12 months'\nGROUP BY DATE_TRUNC('month', w.trx_date)\nORDER BY month"
                        }
                    ]
                },
