                "dataset_query": {
                    "lib/type": "mbql/query",
                    "database": 2,
                    "stages": [
                        {
                            "lib/type": "mbql.stage/native",
                            "native": "SELECT\n    DATE_TRUNC('month', i.created_date) AS month,\n    COUNT(*) AS issues_created,\n    COUNT(CASE WHEN i.status_category = 'Done' THEN 1 END) AS issues_resolved,\n    COUNT(*) - COUNT(CASE WHEN i.status_category = 'Done' THEN 1 END) AS backlog_delta\nFROM core.dim_issues i\nWHERE i.is_subtask = false\n  AND i.issue_type NOT IN ('Epic')\n  AND i.created_date >= CURRENT_DATE - INTERVAL '12 months'\nGROUP BY DATE_TRUNC('month', i.created_date)\nORDER BY month"
                        }
                    ]
                },
