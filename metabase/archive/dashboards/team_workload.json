                "dataset_query": {
                    "lib/type": "mbql/query",
                    "database": 2,
                    "stages": [
                        {
                            "lib/type": "mbql.stage/native",
                            "native": "SELECT\n    u.display_name,\n    DATE_TRUNC('week', w.trx_date) AS week_start,\n    ROUND(SUM(w.time_spent_hours)::numeric, 1) AS hours_logged\nFROM core.fact_worklogs w\nJOIN core.dim_users u ON w.author_id = u.user_id\nWHERE w.trx_date >= CURRENT_DATE - INTERVAL '12 weeks'\nGROUP BY u.display_name, DATE_TRUNC('week', w.trx_date)\nORDER BY week_start DESC, hours_logged DESC"
                        }
                    ]
                },
