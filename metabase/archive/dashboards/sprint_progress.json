                "dataset_query": {
                    "lib/type": "mbql/query",
                    "database": 2,
                    "stages": [
                        {
                            "lib/type": "mbql.stage/native",
                            "native": "SELECT\n    i.project_key,\n    i.status_category,\n    i.status_name,\n    COUNT(*) AS issue_count\nFROM core.dim_issues i\nWHERE i.is_subtask = false\nGROUP BY i.project_key, i.status_category, i.status_name\nORDER BY i.project_key, i.status_category"
                        }
                    ]
                },
