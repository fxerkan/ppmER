          }
        },
        "lib/type": "mbql.stage/native",
        "native": "SELECT deputy_gm_upper_unit,\n  ROUND(SUM(missing_effort_person_days)::numeric,2) AS missing_effort,\n  COUNT(DISTINCT author_name) AS employees,\n  ROUND(AVG(timesheet_entry_percentage)::numeric,1) AS timesheet_pct\nFROM mart.rpt_missing_effort\nWHERE deputy_gm_upper_unit IS NOT NULL [[AND {{date_range}}]] [[AND author_team = {{team}}]]\nGROUP BY deputy_gm_upper_unit ORDER BY missing_effort DESC"
      }
    ]
