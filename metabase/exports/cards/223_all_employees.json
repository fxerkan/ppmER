    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "SELECT display_name, email, team, unit, manager_director, manager_deputy_gm,\n  deputy_gm_upper_unit, outsource_inhouse, is_active, hr_status,\n  ROUND(total_hours_logged::numeric,1) AS total_hours\nFROM core.dim_users \nWHERE 1=1\n  [[AND team = {{team}}]]\n\n  [[AND display_name = {{user_name}}]]\nORDER BY display_name",
