    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "team": {
            "type": "text",
            "id": "33333333-7465616d-1111-1111-111111111111",
            "name": "team",
            "display-name": "Team",
            "required": false
          },
          "date_range": {
            "dimension": [
              "field",
              {
                "base-type": "type/Date",
                "lib/uuid": "45397070-3fd1-4977-a981-9eed8bfa594a",
                "effective-type": "type/Date"
              },
              1105
            ],
            "id": "11111111-1111-1111-1111-111111111111",
            "name": "date_range",
            "display-name": "Date Range",
            "type": "dimension",
            "widget-type": "date/all-options"
          },
          "user_name": {
            "type": "text",
            "id": "44444444-757365726-111-1111-111111111111",
            "name": "user_name",
            "display-name": "User Name",
            "required": false
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "SELECT author_name, author_team, author_unit,\n  ROUND(SUM(total_actual_effort_day)::numeric,1) AS actual_effort,\n  ROUND(SUM(expected_effort_person_days)::numeric,1) AS expected_effort,\n  ROUND(SUM(missing_effort_person_days)::numeric,1) AS missing_effort,\n  ROUND(AVG(timesheet_entry_percentage)::numeric,1) AS avg_entry_pct\nFROM mart.rpt_missing_effort\nWHERE author_name IS NOT NULL [[AND {{date_range}}]]\n  [[AND author_team = {{team}}]] [[AND author_name = {{user_name}}]]\nGROUP BY author_name, author_team, author_unit\nORDER BY missing_effort DESC"
      }
    ]
  },
