  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "team": {
            "type": "text",
            "id": "33333333-7465616d-1111-1111-111111111111",
            "name": "team",
            "display-name": "Team",
            "required": false
          },
          "date_range": {
            "dimension": [
              "field",
              {
                "base-type": "type/Date",
                "lib/uuid": "a49394e2-8fca-4f48-b941-f082d617f652",
                "effective-type": "type/Date"
              },
              1105
            ],
            "id": "11111111-1111-1111-1111-111111111111",
            "name": "date_range",
            "display-name": "Date Range",
            "type": "dimension",
            "widget-type": "date/all-options"
          },
          "user_name": {
            "type": "text",
            "id": "44444444-757365726-111-1111-111111111111",
            "name": "user_name",
            "display-name": "User Name",
            "required": false
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "SELECT author_name, period,\n  SUM(CASE WHEN EXTRACT(DAY FROM trx_date)::int BETWEEN 1  AND 7  THEN missing_effort_person_days END) AS week1,\n  SUM(CASE WHEN EXTRACT(DAY FROM trx_date)::int BETWEEN 8  AND 14 THEN missing_effort_person_days END) AS week2,\n  SUM(CASE WHEN EXTRACT(DAY FROM trx_date)::int BETWEEN 15 AND 21 THEN missing_effort_person_days END) AS week3,\n  SUM(CASE WHEN EXTRACT(DAY FROM trx_date)::int BETWEEN 22 AND 31 THEN missing_effort_person_days END) AS week4,\n  ROUND(SUM(missing_effort_person_days)::numeric,2) AS total_missing\nFROM mart.rpt_missing_effort\nWHERE missing_effort_person_days > 0 AND author_name IS NOT NULL\n  [[AND {{date_range}}]] [[AND author_team = {{team}}]] [[AND author_name = {{user_name}}]]\nGROUP BY author_name, period ORDER BY period DESC, total_missing DESC"
      }
    ]
  },
