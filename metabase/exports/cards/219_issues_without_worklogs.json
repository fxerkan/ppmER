    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "SELECT COUNT(DISTINCT i.issue_key) AS value\nFROM core.dim_issues i\nLEFT JOIN core.fact_worklogs w ON i.issue_key = w.issue_key\nWHERE w.issue_key IS NULL AND i.status_category != 'Done' AND i.is_subtask = false\n  [[AND issue_type_name = {{issue_type}}]]",
