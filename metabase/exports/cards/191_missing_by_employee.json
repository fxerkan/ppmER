            "name": "user_name",
            "display-name": "User Name",
            "required": false
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "SELECT author_name, author_team,\n  ROUND(SUM(missing_effort_person_days)::numeric,2) AS missing_effort,\n  ROUND(SUM(total_actual_effort_day)::numeric,2) AS actual_effort,\n  ROUND(SUM(expected_effort_person_days)::numeric,2) AS expected_effort,\n  ROUND(AVG(timesheet_entry_percentage)::numeric,1) AS timesheet_pct\nFROM mart.rpt_missing_effort\nWHERE 1=1 [[AND {{date_range}}]] [[AND author_team = {{team}}]] [[AND author_name = {{user_name}}]]\nGROUP BY author_name, author_team ORDER BY missing_effort DESC"
      }
    ]
  },
