  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT project_name, customer, category,\n  ROUND(SUM(final_effort)::numeric,1) AS final_effort,\n  ROUND(SUM(final_effort_capex)::numeric,1) AS capex_effort,\n  ROUND(SUM(final_effort_opex)::numeric,1) AS opex_effort,\n  ROUND(SUM(inhouse_effort)::numeric,1) AS inhouse_effort,\n  ROUND(SUM(outsource_effort)::numeric,1) AS outsource_effort\nFROM mart.fact_financial_dashboard_2026\n\nWHERE 1=1\n  [[AND project_name = {{project_key}}]]\n\n  [[AND period = {{period_filter}}]]\nGROUP BY project_name, customer, category\nORDER BY final_effort DESC",
        "template-tags": {
          "project_key": {
            "name": "project_key",
            "display-name": "Project",
            "type": "text",
            "id": "44444444-4444-4444-4444-444444444444",
            "required": false
          },
          "period_filter": {
            "display-name": "Period",
            "type": "text",
            "id": "33333333-3333-3333-3333-333333333333",
            "name": "period_filter",
            "required": false
          }
        }
      }
    ]
  },
