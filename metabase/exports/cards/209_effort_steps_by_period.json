  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT period,\n  ROUND(SUM(logged_time_person_day)::numeric,1) AS base_effort,\n  ROUND(SUM(team_effort)::numeric,1) AS team_effort,\n  ROUND(SUM(tribe_effort)::numeric,1) AS tribe_effort,\n  ROUND(SUM(final_effort)::numeric,1) AS final_effort\nFROM mart.fact_financial_dashboard_2026\n\nWHERE 1=1\n  [[AND period = {{period_filter}}]]\n\n  [[AND team = {{team}}]]\n\n  [[AND project_name = {{project_key}}]]\nGROUP BY period ORDER BY period",
        "template-tags": {
          "period_filter": {
            "name": "period_filter",
            "display-name": "Period",
            "type": "text",
            "id": "33333333-3333-3333-3333-333333333333",
            "required": false
          },
          "team": {
            "name": "team",
