  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "SELECT period,\n  ROUND(SUM(final_effort)::numeric,1) AS final_effort,\n  ROUND(SUM(distributed_effort)::numeric,1) AS distributed_effort\nFROM (\n  SELECT period, project_name, customer, it_domain, tribe, product,\n         business_line, financial_code, is_outsource_inhouse,\n         final_effort, distributed_effort,\n         NULL::numeric AS final_effort_capex, NULL::numeric AS final_effort_opex\n  FROM mart.fact_distributed_efforts_2026\n) d\n\nWHERE 1=1\n  [[AND period = {{period_filter}}]]\n\n  [[AND project_name = {{project_key}}]]\nGROUP BY period ORDER BY period",
        "lib/type": "mbql.stage/native",
        "template-tags": {
          "period_filter": {
            "display-name": "Period",
            "type": "text",
            "id": "33333333-3333-3333-3333-333333333333",
            "name": "period_filter",
            "required": false
          },
