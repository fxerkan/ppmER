    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "SELECT category, ROUND(SUM(final_effort)::numeric,1) AS effort\nFROM mart.fact_financial_dashboard_2026\nWHERE category IS NOT NULL\n\n  [[AND period = {{period_filter}}]]\n\n  [[AND project_name = {{project_key}}]]\nGROUP BY category ORDER BY effort DESC",
