        "dataset_query": {
          "lib/type": "mbql/query",
          "database": 2,
          "stages": [
            {
              "native": "SELECT issue_type, issue_type_name, capex_opex, issue_type_category,\n  COUNT(*) AS worklog_count,\n  ROUND(SUM(time_spent_hours)::numeric,1) AS total_hours\nFROM core.fact_worklogs\nWHERE issue_type_name IS NOT NULL\n\n  [[AND issue_type_name = {{issue_type}}]]\nGROUP BY issue_type, issue_type_name, capex_opex, issue_type_category\nORDER BY worklog_count DESC",
              "lib/type": "mbql.stage/native",
              "template-tags": {
                "issue_type": {
