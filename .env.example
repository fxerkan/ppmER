# ===================================
# Jira PPM Data Stack - Configuration
# Copy this file to .env and fill in your values
# ===================================

# === PostgreSQL ===
POSTGRES_USER=ppm_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ppm_datawarehouse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=15432

# === Jira ===
JIRA_SUBDOMAIN=your-company
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_START_DATE=2023-01-01
JIRA_LOOKBACK_BUFFER_DAYS=3

# === Mage AI Orchestration ===
MAGE_PORT=6789

# === dbt Docs ===
DBT_DOCS_EXTERNAL_PORT=8081

# === CloudBeaver Database UI ===
CLOUDBEAVER_EXTERNAL_PORT=8978
CB_ADMIN_NAME=admin
CB_ADMIN_PASSWORD=change_me_admin_pass

# === Metabase BI Dashboard ===
METABASE_EXTERNAL_PORT=3000
# Internal metadata database (Metabase's own DB)
MB_DB_TYPE=postgres
MB_DB_HOST=${POSTGRES_HOST}
MB_DB_PORT=${POSTGRES_PORT}
MB_DB_DBNAME=metabase
MB_DB_USER=${POSTGRES_USER}
MB_DB_PASS=${POSTGRES_PASSWORD}
# Auto-provision admin user (skips setup wizard on first start)
# Change these before deploying to production!
MB_ADMIN_EMAIL=admin@ppm.local
MB_ADMIN_PASSWORD=PpmAdmin123!
MB_ADMIN_NAME=PPM Admin

# === AI Agent / Chat UI ===
AGENT_PORT=7860
# Bring your own API key (Claude, OpenAI, Gemini, or local Ollama)
OPENAI_API_KEY=your-openai-or-claude-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# === Data File Upload Service ===
UPLOAD_EXTERNAL_PORT=8085

# === Central Portal ===
PORTAL_EXTERNAL_PORT=9000
PORTAL_ADMIN_PASS=change_me_admin
PORTAL_DEV_PASS=change_me_dev
PORTAL_ANALYST_PASS=change_me_analyst
PORTAL_USER_PASS=change_me_user

# === Email Notifications (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_MAIL_FROM=
SMTP_SSL=False
SMTP_STARTTLS=True
SMTP_USE_TLS=False

# === Volume Storage ===
VOLUME_BASE_PATH=./volumes

# === Pipeline Settings ===
STUCK_PIPELINE_MULTIPLIER=3
