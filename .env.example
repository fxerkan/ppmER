# ===================================
# ppmER — Project & Portfolio Management Data Stack
# Copy this file to .env and fill in your values
# ===================================

# === PostgreSQL ===
POSTGRES_USER=ppm_user
POSTGRES_PASSWORD=Jppm@min123
POSTGRES_DB=ppm_datawarehouse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=15432

# === Jira ===
JIRA_SUBDOMAIN=your-company
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_START_DATE=2023-01-01
JIRA_LOOKBACK_BUFFER_DAYS=3

# === Mage AI Orchestration ===
MAGE_PORT=6789

# === dbt Docs ===
DBT_DOCS_EXTERNAL_PORT=8081

# === CloudBeaver Database UI ===
CLOUDBEAVER_EXTERNAL_PORT=8978
CB_ADMIN_NAME=cbadmin
CB_ADMIN_PASSWORD=Jppm@min123
CB_ANALYST_PASSWORD=Jppm@min123
CB_POWER_USER_PASSWORD=Jppm@min123
PG_ANALYST_PASSWORD=ppm_analyst_123
PG_POWER_USER_PASSWORD=ppm_power_user_123

# === Metabase BI Dashboard ===
METABASE_EXTERNAL_PORT=3000
MB_DB_TYPE=postgres
MB_DB_HOST=${POSTGRES_HOST}
MB_DB_PORT=${POSTGRES_PORT}
MB_DB_DBNAME=metabase
MB_DB_USER=${POSTGRES_USER}
MB_DB_PASS=${POSTGRES_PASSWORD}
MB_ADMIN_EMAIL=admin@jppm.local
MB_ADMIN_PASSWORD=Jppm@min123
MB_ADMIN_NAME=admin
# API key for Metabase MCP (generate via: metabase/setup.sh or Metabase Admin → API Keys)
MB_API_KEY=

# === AI Agent / Chat UI ===
# Supported LLM providers — set at least one API key
AGENT_PORT=7860
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_MODEL=gemini-2.0-flash
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_MODEL=qwen2.5-coder:7b

# === Data File Upload Service ===
UPLOAD_EXTERNAL_PORT=8085

# === Central Portal ===
# Set PUBLIC_HOST to your server's domain/IP for production (e.g. myserver.example.com)
PUBLIC_HOST=localhost
PORTAL_EXTERNAL_PORT=9000
PORTAL_ADMIN_PASS=Jppm@min123
PORTAL_DEV_PASS=Jppm@min123
PORTAL_ANALYST_PASS=Jppm@min123
PORTAL_USER_PASS=Jppm@min123

# === Portal Database (ppmdatastack) — now in main postgres container ===
PORTAL_DB_USER=ppm_portal
PORTAL_DB_PASSWORD=Jppm@min123
PORTAL_DB_NAME=ppmdatastack
# PORTAL_DB_EXTERNAL_PORT=15433  # Removed — now shared with main postgres via ${POSTGRES_EXTERNAL_PORT}

# === Email Notifications (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_MAIL_FROM=
SMTP_SSL=False
SMTP_STARTTLS=True
SMTP_USE_TLS=False

# === Volume Storage ===
# Pattern: /Users/<you>/DATA/container_volumes/<project_name>
VOLUME_BASE_PATH=/Users/erkan.ciftci/DATA/container_volumes/ppmER

# === Pipeline Settings ===
STUCK_PIPELINE_MULTIPLIER=3
